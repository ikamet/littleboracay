<script>
  /* Nav scroll shadow */
  const navBar = document.getElementById('nav-bar');
  window.addEventListener('scroll', () => {
    navBar?.classList.toggle('scrolled', window.scrollY > 16);
  }, { passive: true });

  /* Burger toggle */
  const burger = document.getElementById('nav-burger');
  const mobileNav = document.getElementById('nav-mobile');
  burger?.addEventListener('click', function() {
    const open = mobileNav?.getAttribute('aria-hidden') === 'true';
    mobileNav?.setAttribute('aria-hidden', open ? 'false' : 'true');
    this.setAttribute('aria-expanded', open ? 'true' : 'false');
    this.classList.toggle('open', open);
  });

  /* Smooth scroll for #anchors */
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const id = (a as HTMLAnchorElement).getAttribute('href')?.slice(1);
      const t = id ? document.getElementById(id) : null;
      if (!t) return;
      e.preventDefault();
      window.scrollTo({ top: t.getBoundingClientRect().top + window.scrollY - 72, behavior: 'smooth' });
      mobileNav?.setAttribute('aria-hidden', 'true');
      burger?.classList.remove('open');
    });
  });

  /* Form helper — call window.bindForm(formId, btnId, okId) from any page */
  window.bindForm = function(formId: string, btnId: string, okId: string) {
    const form = document.getElementById(formId) as HTMLFormElement;
    const btn  = document.getElementById(btnId) as HTMLButtonElement;
    const ok   = document.getElementById(okId);
    if (!form || !btn || !ok) return;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      btn.textContent = 'Sending…';
      btn.disabled = true;
      setTimeout(() => {
        form.querySelectorAll('.form-group, .form-row').forEach((el: Element) => {
          (el as HTMLElement).style.display = 'none';
        });
        btn.style.display = 'none';
        ok.classList.add('show');
        ok.style.display = 'flex';
      }, 1200);
    });
  };
</script>

<style>
/* NAV */
.nav-bar {
  position: sticky; top: 0; z-index: 200;
  background: rgba(255,255,255,.97);
  border-bottom: 1px solid transparent;
  backdrop-filter: blur(10px);
  transition: border-color .2s, box-shadow .2s;
}
.nav-bar.scrolled {
  border-bottom-color: var(--border);
  box-shadow: var(--sh-xs);
}
.nav-inner {
  max-width: var(--max); margin: 0 auto; padding: 0 24px;
  height: var(--nav-h);
  display: flex; align-items: center; gap: 28px;
}
.nav-brand {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none; flex-shrink: 0;
}
.nav-brand:hover { text-decoration: none; }
.nav-logo-img { border-radius: 50%; object-fit: cover; flex-shrink: 0; }
.nav-brand-name { display: block; font-size: .95rem; font-weight: 700; color: var(--navy); letter-spacing: -.01em; }
.nav-brand-sub { display: block; font-size: .66rem; color: var(--text-3); }
.nav-links { display: flex; align-items: center; gap: 0; margin-left: auto; }
.nav-links a {
  padding: 6px 13px; font-size: .865rem; font-weight: 500;
  color: var(--text-2); border-radius: var(--r); transition: .15s; text-decoration: none;
}
.nav-links a:hover, .nav-links a.active {
  color: var(--navy); background: rgba(13,43,107,.06); text-decoration: none;
}
.nav-right { margin-left: 12px; }
.nav-burger {
  display: none; flex-direction: column; gap: 5px;
  background: none; border: none; cursor: pointer; padding: 4px; margin-left: auto;
}
.nav-burger span {
  display: block; width: 20px; height: 1.5px;
  background: var(--text); border-radius: 2px; transition: .22s;
}
.nav-burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.nav-burger.open span:nth-child(2) { opacity: 0; }
.nav-burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
.nav-mobile {
  display: none; flex-direction: column;
  padding: 10px 24px 20px; border-top: 1px solid var(--border); gap: 2px;
}
.nav-mobile[aria-hidden="false"] { display: flex; }
.nav-mobile a {
  padding: 9px 12px; border-radius: var(--r);
  color: var(--text); font-weight: 500; font-size: .9rem; text-decoration: none;
}
.nav-mobile a:hover { background: var(--bg-alt); text-decoration: none; }
.mob-cta {
  margin-top: 8px; padding: 10px 12px !important;
  background: var(--navy) !important; color: white !important;
  border-radius: var(--r) !important; text-align: center;
  font-weight: 700 !important;
}

/* FOOTER */
.site-footer { background: #111827; }
.footer-main {
  display: grid;
  grid-template-columns: 2.2fr 1fr 1fr 1fr;
  gap: 48px;
  padding: 60px 24px 48px;
  max-width: var(--max); margin: 0 auto;
}
.footer-brand-link { text-decoration: none !important; }
.footer-desc { font-size: .84rem; color: rgba(255,255,255,.48); line-height: 1.65; margin: 14px 0 18px; max-width: 320px; }
.footer-socials { display: flex; gap: 7px; margin-bottom: 16px; flex-wrap: wrap; }
.fsoc {
  display: flex; align-items: center; justify-content: center;
  width: 32px; height: 32px; border-radius: var(--r);
  background: rgba(255,255,255,.07); color: rgba(255,255,255,.55); transition: .15s;
}
.fsoc:hover { background: var(--navy-l); color: white; text-decoration: none; }
.footer-trust { display: flex; gap: 8px; flex-wrap: wrap; }
.footer-trust-badge {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 10px; background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.1); border-radius: 999px;
  font-size: .72rem; font-weight: 500; color: rgba(255,255,255,.6);
  text-decoration: none; transition: .15s;
}
.footer-trust-badge:hover { background: rgba(255,255,255,.14); color: white; text-decoration: none; }
.footer-col h4 { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .09em; color: rgba(255,255,255,.28); margin-bottom: 14px; }
.footer-col a { display: block; font-size: .84rem; color: rgba(255,255,255,.55); text-decoration: none; margin-bottom: 10px; transition: color .15s; }
.footer-col a:hover { color: white; text-decoration: none; }
.footer-bottom { border-top: 1px solid rgba(255,255,255,.06); padding: 18px 0; }
.footer-bottom-inner { max-width: var(--max); margin: 0 auto; padding: 0 24px; display: flex; flex-direction: column; gap: 4px; }
.footer-bottom p { font-size: .76rem; color: rgba(255,255,255,.3); line-height: 1.8; }
.footer-follow a { color: rgba(255,255,255,.55); text-decoration: none; transition: color .15s; }
.footer-follow a:hover { color: white; }
.footer-follow strong { color: rgba(255,255,255,.7); }

@media (max-width: 1024px) {
  .footer-main { grid-template-columns: 1fr 1fr; gap: 32px; }
  .footer-brand-col { grid-column: span 2; }
}
@media (max-width: 900px) {
  .nav-links, .nav-right { display: none; }
  .nav-burger { display: flex; }
  .footer-main { grid-template-columns: 1fr 1fr; }
  .footer-brand-col { grid-column: span 2; }
}
@media (max-width: 600px) {
  .footer-main { grid-template-columns: 1fr; }
  .footer-brand-col { grid-column: auto; }
}
</style>
</body>
</html>
