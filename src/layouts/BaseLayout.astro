---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  schema?: object | object[];
}

const {
  title = "Little Boracay Calatagan Batangas | Sandbar & Tours",
  description = "Explore Little Boracay in Calatagan, Batangas. Boat tours, floating cottages, crystal waters, white sandbars, and water activities near Calatagan beach.",
  image = "/og-image.jpg",
  type = "website",
  schema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.site);
const path = Astro.url.pathname;

const baseSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Little Boracay",
  "description": "A natural sandbar in Calatagan, Batangas known for floating bamboo cottages, shallow turquoise waters, and boat tours from Manila.",
  "url": "https://littleboracay.com",
  "image": "https://littleboracay.com/og-image.jpg",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Calatagan",
    "addressRegion": "Batangas",
    "addressCountry": "PH"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "13.8198041",
    "longitude": "120.6157737"
  },
  "hasMap": "https://maps.app.goo.gl/dDyEJhYkpxW2gxCt8",
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "08:00",
    "closes": "17:00"
  }],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.3",
    "reviewCount": "3",
    "bestRating": "5"
  },
  "sameAs": [
    "https://maps.app.goo.gl/dDyEJhYkpxW2gxCt8",
    "https://facebook.com/littleboracay",
    "https://facebook.com/groups/littleboracay",
    "https://instagram.com/littleboracay",
    "https://tiktok.com/@littleboracay",
    "https://www.tripadvisor.com/Attraction_Review-g1209360-d17381413-Reviews-Little_Boracay-Calatagan_Batangas_Province_Calabarzon_Region_Luzon.html",
    "https://www.trustpilot.com/review/littleboracay.com"
  ]
};

const schemas = [baseSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={socialImage} />
  <meta property="og:locale" content="en_PH" />
  <meta property="og:site_name" content="Little Boracay" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={socialImage} />

  <!-- Geo / AEO -->
  <meta name="geo.region" content="PH-BAT" />
  <meta name="geo.placename" content="Calatagan, Batangas, Philippines" />
  <meta name="geo.position" content="13.8198041;120.6157737" />
  <meta name="ICBM" content="13.8198041, 120.6157737" />

  <!-- Schema -->
  {schemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
