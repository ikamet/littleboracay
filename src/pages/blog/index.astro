---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  { slug: "how-to-get-to-little-boracay-from-manila", title: "How to Get to Little Boracay from Manila: Complete 2026 Guide", date: "2026-04-18", tag: "Travel Guide", desc: "Step-by-step directions from Metro Manila to Little Boracay sandbar in Calatagan, Batangas — drive route, boat transfer, tips, and a sample day trip itinerary." },
  { slug: "starfish-sandbar-calatagan", title: "Discover Starfish Sandbar by Floating Cottage — The Ultimate Tour", date: "2026-04-10", tag: "Tours", desc: "Journey to Little Boracay for snorkeling, dining, and relaxing on a floating cottage, followed by exploring the enchanting Starfish Sandbar. Everything you need to know." },
  { slug: "floating-cottages-little-boracay", title: "Everything You Need to Know About the Floating Cottages at Little Boracay", date: "2026-03-28", tag: "Activities", desc: "What are the floating bamboo cottages at Little Boracay? How to book, what to bring, and why this over-water experience is the most popular activity in Calatagan." },
  { slug: "little-boracay-vs-boracay", title: "Little Boracay vs. Boracay Island: What's the Difference?", date: "2026-03-15", tag: "Destination", desc: "A complete comparison of Little Boracay in Calatagan, Batangas and Boracay Island in Aklan — scenery, access, cost, and which one is right for your trip." },
  { slug: "best-time-to-visit-little-boracay", title: "Best Time to Visit Little Boracay Calatagan Batangas", date: "2026-02-20", tag: "Planning", desc: "When is the best time to visit Little Boracay? Complete guide to seasons, tides, time of day, and how to plan your trip for the best sandbar conditions." },
  { slug: "calatagan-batangas-travel-guide", title: "Calatagan, Batangas Travel Guide: Beaches, Sandbars & Day Trips", date: "2026-01-30", tag: "Destination", desc: "Everything to know about Calatagan, Batangas — Little Boracay sandbar, CaSoBe, Stilts Resort, beaches, how to get there, and what to do on your visit." }
];
---
<BaseLayout
  title="Little Boracay Blog | Travel Guides, Tips & Destination Info"
  description="Travel guides, visitor tips, and destination information about Little Boracay sandbar and Calatagan, Batangas. Plan your perfect trip with our expert guides."
>
<div class="page-hero">
  <div class="container">
    <span class="overline">Travel Blog</span>
    <h1>Little Boracay Travel Guides</h1>
    <p class="page-lead">Destination guides, travel tips, and visitor information for Little Boracay sandbar and Calatagan, Batangas.</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="blog-grid">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="blog-card">
          <div class="blog-card-body">
            <div class="blog-card-tag">{post.tag}</div>
            <h3>{post.title}</h3>
            <p>{post.desc}</p>
            <div class="blog-card-meta">
              <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}</time>
              <span class="read-more">Read guide →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<div class="cta-band">
  <div class="container cta-band-inner">
    <div><h2>Ready to Visit Little Boracay?</h2><p>Book your floating cottage and experience the sandbar for yourself.</p></div>
    <div class="cta-actions">
      <a href="/contact" class="btn btn-yellow btn-lg">Book Now</a>
      <a href="/visit" class="btn btn-outline-white btn-lg">Travel Guide</a>
    </div>
  </div>
</div>
</BaseLayout>

<style>
.page-hero { padding: 60px 0 40px; background: linear-gradient(to bottom, rgba(13,43,107,.06), var(--bg)); border-bottom: 1px solid var(--border); }
.page-hero h1 { font-size: clamp(2rem, 4vw, 2.6rem); font-weight: 800; color: var(--text); margin: 10px 0 14px; letter-spacing: -.03em; }
.page-lead { font-size: 1.05rem; color: var(--text-2); max-width: 560px; line-height: 1.7; }
.blog-card-meta { display: flex; justify-content: space-between; align-items: center; }
.read-more { font-size: .78rem; font-weight: 600; color: var(--navy); }
</style>
