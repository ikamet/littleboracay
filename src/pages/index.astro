        <div class="rating-links">
          <a href="https://www.tripadvisor.com/Attraction_Review-g1209360-d17381413-Reviews-Little_Boracay-Calatagan_Batangas_Province_Calabarzon_Region_Luzon.html" target="_blank" rel="noopener" class="r-link">
            <svg width="12" height="12" viewBox="0 0 20 20"><circle cx="10" cy="10" r="9" fill="#00AF87"/><circle cx="10" cy="10" r="4" fill="white"/><circle cx="10" cy="10" r="2" fill="#00AF87"/></svg>
            Read reviews on TripAdvisor
          </a>
          <a href="https://maps.app.goo.gl/dDyEJhYkpxW2gxCt8" target="_blank" rel="noopener" class="r-link">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="#EA4335"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            View on Google Maps
