---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustStrip from '../components/TrustStrip.astro';

const pageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Little Boracay Calatagan Batangas | Sandbar & Tours",
    "url": "https://littleboracay.com",
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".speakable"]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is Little Boracay in Calatagan, Batangas?", "acceptedAnswer": { "@type": "Answer", "text": "Little Boracay is a natural tidal sandbar in Calatagan, Batangas, Philippines. Known for shallow turquoise waters, white sand, and floating bamboo cottages. Accessed by boat from the coastal barangays of Calatagan." }},
      { "@type": "Question", "name": "How far is Little Boracay from Manila?", "acceptedAnswer": { "@type": "Answer", "text": "Approximately 3 to 4 hours from Metro Manila by car via the South Luzon Expressway (SLEX) and STAR Tollway." }},
      { "@type": "Question", "name": "Are floating cottages available at Little Boracay?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Floating bamboo cottages are one of the signature features of Little Boracay, available through local boat operators." }},
      { "@type": "Question", "name": "Is Little Boracay the same as Boracay Island?", "acceptedAnswer": { "@type": "Answer", "text": "No. Little Boracay is a separate natural sandbar in Calatagan, Batangas. Boracay Island is in Malay, Aklan, accessed by plane and ferry from Manila." }},
      { "@type": "Question", "name": "What is the best time to visit Little Boracay?", "acceptedAnswer": { "@type": "Answer", "text": "Morning to early afternoon during low tide. The dry season from November to May offers the most reliable weather." }},
      { "@type": "Question", "name": "How do I book a floating cottage at Little Boracay?", "acceptedAnswer": { "@type": "Answer", "text": "Contact us through our website, Facebook page, or call local operators in Calatagan. We recommend booking in advance especially on weekends and Philippine holidays." }}
    ]
  }
];
---

<BaseLayout
  title="Little Boracay Calatagan Batangas | Sandbar & Tours"
  description="Explore Little Boracay in Calatagan, Batangas. Boat tours, floating cottages, crystal waters, white sandbars, and water activities near Calatagan beach."
  schema={pageSchema}
>

<!-- ══════════ HERO ══════════ -->
<section class="hero" id="hero">
  <div class="hero-inner container">
    <div class="hero-content">
      <div class="hero-eyebrow">
        <span class="eyebrow-dot"></span>
        Calatagan, Batangas · Philippines
      </div>
      <h1 class="speakable">
        Batangas' Most<br>
        Iconic<br>
        <span class="h1-underline">Natural Sandbar</span>
      </h1>
      <p class="hero-sub speakable">
        Float above turquoise waters on a bamboo cottage. Swim in a natural sandbar just <strong>3–4 hours from Metro Manila</strong>. No flight needed.
      </p>
      <div class="hero-ctas">
        <a href="#book" class="btn btn-yellow btn-lg">Book Your Visit</a>
        <a href="#about" class="btn btn-outline-white btn-lg">Learn More</a>
      </div>
      <div class="hero-stats">
        <div class="hstat"><strong>★ 4.3</strong><span>TripAdvisor</span></div>
        <div class="hstat-div"></div>
        <div class="hstat"><strong>3–4 hrs</strong><span>From Manila</span></div>
        <div class="hstat-div"></div>
        <div class="hstat"><strong>Natural</strong><span>Sandbar</span></div>
        <div class="hstat-div"></div>
        <div class="hstat"><strong>Floating</strong><span>Cottages</span></div>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <div class="hero-logo-frame">
        <img src="/logo.png" alt="Little Boracay Calatagan" class="hero-logo" width="360" height="360" />
        <div class="hero-logo-tag">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--navy)"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          Calatagan, Batangas
        </div>
      </div>
    </div>
  </div>
</section>

<TrustStrip />

<!-- ══════════ ABOUT ══════════ -->
<section class="section" id="about">
  <div class="container">
    <div class="about-layout">
      <div class="about-text">
        <span class="overline">The Destination</span>
        <h2 class="section-title">What is Little Boracay?</h2>
        <p class="body-lg speakable">
          <strong>Little Boracay</strong> is a natural tidal sandbar off the western coastline of <strong>Calatagan, Batangas</strong>, facing the South China Sea. It earned its name from a striking resemblance to the famous Boracay Island — the same white sand and turquoise-clear shallow water — but reachable from Metro Manila without a flight.
        </p>
        <p>
          Unlike a beach resort, Little Boracay is entirely a natural environment — a shifting sandbar that changes with the tides. Visitors arrive by short boat transfer from Calatagan's coastal barangays, where iconic <strong>floating bamboo cottages</strong> are anchored over the shallow water.
        </p>
        <p>
          The destination is popular for weekend day trips, family outings, drone photography, and group gatherings on the floating cottages.
        </p>
        <div class="about-feats">
          <div class="about-feat">
            <div class="feat-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div><strong>3–4 hrs from Manila</strong><span>No flight required</span></div>
          </div>
          <div class="about-feat">
            <div class="feat-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
            </div>
            <div><strong>Floating cottages</strong><span>Bamboo over shallow water</span></div>
          </div>
          <div class="about-feat">
            <div class="feat-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div><strong>Natural sandbar</strong><span>Not a resort — pure nature</span></div>
          </div>
          <div class="about-feat">
            <div class="feat-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div><strong>Family-friendly</strong><span>Calm, shallow, safe waters</span></div>
          </div>
        </div>
        <div class="about-ctas">
          <a href="/sandbar" class="btn btn-navy">About the Sandbar</a>
          <a href="/cottages" class="btn btn-outline">Floating Cottages</a>
        </div>
      </div>
      <div class="about-facts">
        <div class="fact-table">
          <div class="fact-table-header">Quick Facts</div>
          <div class="fact-row"><span>Type</span><strong>Natural tidal sandbar</strong></div>
          <div class="fact-row"><span>Location</span><strong>Calatagan, Batangas, PH</strong></div>
          <div class="fact-row"><span>Coordinates</span><strong>13.8198°N · 120.6158°E</strong></div>
          <div class="fact-row"><span>Body of water</span><strong>South China Sea</strong></div>
          <div class="fact-row"><span>Access</span><strong>Boat only from coast</strong></div>
          <div class="fact-row"><span>From Manila</span><strong>3–4 hour drive</strong></div>
          <div class="fact-row"><span>Best time</span><strong>Morning low tide</strong></div>
          <div class="fact-row"><span>Peak season</span><strong>November – May</strong></div>
          <div class="fact-row"><span>Hours</span><strong>8:00 AM – 5:00 PM</strong></div>
          <div class="fact-row"><span>TripAdvisor</span><strong>★ 4.3 · Travelers' Choice</strong></div>
        </div>
        <a href="https://maps.app.goo.gl/dDyEJhYkpxW2gxCt8" target="_blank" rel="noopener" class="btn btn-navy" style="width:100%;justify-content:center;margin-top:12px;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
          View on Google Maps
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════ ACTIVITIES ══════════ -->
<section class="section section-alt" id="activities">
  <div class="container">
    <span class="overline">Things To Do</span>
    <h2 class="section-title">Activities at Little Boracay</h2>
    <p class="section-intro">Whether you're after a relaxing float on a bamboo cottage or an underwater adventure, there's something for every visitor.</p>
    <div class="act-grid">
      <div class="act-card">
        <div class="act-num">01</div>
        <h3>Boat Tours to the Sandbar</h3>
        <p>Local operators run short boat transfers from Calatagan's coastal barangays directly to Little Boracay. Book in advance on weekends and holidays.</p>
        <a href="/things-to-do#boat-tours" class="act-link">Learn more →</a>
      </div>
      <div class="act-card featured">
        <div class="act-num">02</div>
        <span class="badge badge-yellow" style="margin-bottom:10px;display:inline-flex;">Most Popular</span>
        <h3>Floating Cottage Experience</h3>
        <p>The signature Little Boracay activity. Bamboo cottages anchored over crystal-clear shallow water — swim, relax, eat, and enjoy 360° sea views.</p>
        <a href="/cottages" class="act-link act-link-white">Book a cottage →</a>
      </div>
      <div class="act-card">
        <div class="act-num">03</div>
        <h3>Swimming &amp; Wading</h3>
        <p>The calm, warm, shallow waters are ideal for all ages. Clear visibility to the sandy bottom makes it one of Batangas' best family swim spots.</p>
        <a href="/things-to-do#swimming" class="act-link">Learn more →</a>
      </div>
      <div class="act-card">
        <div class="act-num">04</div>
        <h3>Snorkeling</h3>
        <p>Explore coastal marine life in the clear waters around the sandbar. Bring your own gear or ask local operators about equipment rental.</p>
        <a href="/things-to-do#snorkeling" class="act-link">Learn more →</a>
      </div>
      <div class="act-card">
        <div class="act-num">05</div>
        <h3>Photography &amp; Drone</h3>
        <p>One of Batangas' most photogenic spots. Aerial drone photography over the tidal sandbar at low tide is spectacular. Always follow CAAP regulations.</p>
        <a href="/things-to-do#photography" class="act-link">Learn more →</a>
      </div>
      <div class="act-card">
        <div class="act-num">06</div>
        <h3>Island Day Trips</h3>
        <p>The perfect full-day Manila escape. Leave early, arrive by 9 AM, spend the day at the sandbar, and be home by evening. Perfect for barkada, family, and corporate groups.</p>
        <a href="/visit" class="act-link">Plan your trip →</a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════ HOW TO VISIT ══════════ -->
<section class="section" id="how-to-visit">
  <div class="container">
    <div class="visit-layout">
      <div class="visit-left">
        <span class="overline">How to Get There</span>
        <h2 class="section-title">Getting to Little Boracay</h2>
        <p>From Manila to the sandbar in 4 simple steps.</p>
        <div class="step-list">
          <div class="step-item">
            <div class="step-num">01</div>
            <div class="step-content">
              <h3>Drive from Metro Manila</h3>
              <p>Take the <strong>South Luzon Expressway (SLEX)</strong> south then merge onto the <strong>STAR Tollway</strong>. Drive time is <strong>3–4 hours</strong>. Leave by 5–6 AM on weekends to beat traffic.</p>
            </div>
          </div>
          <div class="step-item">
            <div class="step-num">02</div>
            <div class="step-content">
              <h3>Navigate to Calatagan</h3>
              <p>Exit toward <strong>Lian, Batangas</strong> then follow roads to Calatagan. Use Google Maps or Waze and search "Little Boracay Calatagan".</p>
            </div>
          </div>
          <div class="step-item">
            <div class="step-num">03</div>
            <div class="step-content">
              <h3>Reach the Jump-Off Point</h3>
              <p>Head to the coastal barangays of Calatagan where local boat operators are based. <strong>Book cottages in advance</strong> — especially on weekends.</p>
            </div>
          </div>
          <div class="step-item">
            <div class="step-num">04</div>
            <div class="step-content">
              <h3>Boat to the Sandbar</h3>
              <p>The boat ride takes <strong>10–20 minutes</strong>. Always confirm with operators the day before as boats may not run in rough weather or very high tides.</p>
            </div>
          </div>
        </div>
        <div class="visit-seasons">
          <div class="season-pill" style="background:var(--green-bg);border:1px solid var(--green-bd);">
            <strong>✅ Nov – May</strong>
            <span>Dry season — best weather and sea conditions</span>
          </div>
          <div class="season-pill" style="background:var(--amber-bg);border:1px solid var(--amber-bd);">
            <strong>⚠️ Jun – Oct</strong>
            <span>Typhoon season — check conditions first</span>
          </div>
        </div>
        <a href="/visit" class="btn btn-navy" style="margin-top:20px;">Full Travel Guide →</a>
      </div>

      <!-- BOOK FORM -->
      <div class="form-panel" id="book">
        <div class="form-panel-head">
          <h3>Plan Your Visit</h3>
          <p>Fill in your details and we'll get back to you with everything you need.</p>
        </div>
        <form id="planForm" class="form-body" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="p-name">Your Name *</label>
              <input type="text" id="p-name" placeholder="Juan dela Cruz" required />
            </div>
            <div class="form-group">
              <label for="p-email">Email Address *</label>
              <input type="email" id="p-email" placeholder="juan@email.com" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="p-date">Preferred Date</label>
              <input type="date" id="p-date" />
            </div>
            <div class="form-group">
              <label for="p-guests">Group Size</label>
              <select id="p-guests">
                <option value="">Select...</option>
                <option>Solo / couple (1–2)</option>
                <option>Small group (3–5)</option>
                <option>Medium group (6–10)</option>
                <option>Large group (11–20)</option>
                <option>Big event (20+)</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="p-type">Type of Visit</label>
            <select id="p-type">
              <option value="">Select...</option>
              <option>Day trip with floating cottage</option>
              <option>Family outing</option>
              <option>Barkada / friend group</option>
              <option>Corporate / team building</option>
              <option>Photography / drone shoot</option>
              <option>Special occasion / celebration</option>
            </select>
          </div>
          <div class="form-group">
            <label for="p-from">Travelling from</label>
            <input type="text" id="p-from" placeholder="e.g. Makati, BGC, Quezon City…" />
          </div>
          <div class="form-group">
            <label for="p-notes">Questions or special requests</label>
            <textarea id="p-notes" rows="3" placeholder="Dietary needs, accessibility, large group arrangements…"></textarea>
          </div>
          <button type="submit" class="btn btn-navy" style="width:100%;justify-content:center;" id="planBtn">
            Send My Visit Plan
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
          <div class="form-success" id="planOk">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <div>
              <strong>You're all set!</strong>
              <p>We'll be in touch with your full Little Boracay visitor guide. See you at the sandbar!</p>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

