---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main class="container">

			<!-- HERO SECTION -->
			<section class="hero">
				<h1>Little Boracay Calatagan, Batangas</h1>
				<p>
					Discover Little Boracay in Calatagan, Batangas — a scenic sandbar destination known for 
					crystal-clear waters, white sand areas, floating bamboo cottages, and relaxing coastal 
					day trips just a few hours from Metro Manila.
				</p>
			</section>

			<!-- ABOUT DESTINATION -->
			<section>
				<h2>What is Little Boracay?</h2>

				<p>
					Little Boracay is a well-known sandbar destination located off the coast of 
					<strong>Calatagan, Batangas</strong>. The area is famous for its shallow turquoise 
					waters, wide sandbar formations, and floating bamboo cottages anchored offshore.
				</p>

				<p>
					Visitors travel by boat from the coastal barangays of Calatagan to reach the 
					sandbar, where the calm waters and open sea views create one of the most unique 
					beach environments in southern Luzon.
				</p>

				<p>
					The destination has become increasingly popular for day trips, group outings, 
					beach photography, and floating cottage gatherings.
				</p>
			</section>

			<!-- ACTIVITIES -->
			<section>
				<h2>Things to Do in Little Boracay</h2>

				<ul>
					<li>Boat tours to the sandbar</li>
					<li>Floating cottage rentals</li>
					<li>Swimming in shallow clear waters</li>
					<li>Snorkeling and water activities</li>
					<li>Group day trips and beach gatherings</li>
					<li>Coastal photography and drone photography</li>
				</ul>

				<p>
					Because the sandbar appears depending on tide conditions, every visit offers 
					a slightly different view of the coastline and surrounding waters.
				</p>
			</section>

			<!-- HOW TO GET THERE -->
			<section>
				<h2>How to Get to Little Boracay Calatagan</h2>

				<p>
					Travelers typically drive from Metro Manila to Calatagan, Batangas — a journey 
					that usually takes around three to four hours depending on traffic conditions.
				</p>

				<p>
					From the coastal areas of Calatagan, visitors arrange boat transfers to reach 
					the Little Boracay sandbar and floating cottage areas.
				</p>

				<p>
					Boat access depends on local weather conditions and tides.
				</p>
			</section>

			<!-- WHY VISIT -->
			<section>
				<h2>Why Visit Little Boracay?</h2>

				<ul>
					<li>Closer alternative to Boracay Island</li>
					<li>Unique sandbar environment</li>
					<li>Floating cottages directly over shallow waters</li>
					<li>Popular for weekend beach escapes</li>
					<li>Accessible coastal destination from Manila</li>
				</ul>
			</section>

			<!-- COMMUNITY -->
			<section>
				<h2>The Little Boracay Community</h2>

				<p>
					LittleBoracay.com supports a growing community of travelers, beach enthusiasts, 
					and photographers who share experiences about visiting the sandbar and exploring 
					the Calatagan coastline.
				</p>

				<p>
					Through the Little Boracay community channels, visitors exchange travel tips, 
					share beach photos, and help others discover one of the most unique sandbar 
					destinations in Batangas.
				</p>

				<p>
					<strong>Official Website:</strong> littleboracay.com<br />
					<strong>Facebook Page:</strong> 
					<a href="https://facebook.com/littleboracay" target="_blank" rel="noopener">
						facebook.com/littleboracay
					</a><br />
					<strong>Community Group:</strong> 
					<a href="https://facebook.com/groups/littleboracay" target="_blank" rel="noopener">
						Little Boracay – Calatagan Floating Cottages & Beach Community
					</a>
				</p>
			</section>

			<!-- FAQ -->
			<section>
				<h2>Frequently Asked Questions</h2>

				<h3>Is Little Boracay a resort?</h3>
				<p>
					No. Little Boracay is a natural sandbar destination accessed by boat. 
					It is not a traditional beach resort.
				</p>

				<h3>Are boat tours required?</h3>
				<p>
					Yes. Visitors must arrange boat transportation from Calatagan to reach 
					the sandbar area.
				</p>

				<h3>Is Little Boracay suitable for children?</h3>
				<p>
					Yes. The shallow waters make the sandbar suitable for families, although 
					children should always be supervised when swimming.
				</p>

				<h3>How far is Little Boracay from Manila?</h3>
				<p>
					The travel time from Metro Manila to Calatagan typically ranges between 
					three and four hours by car depending on traffic conditions.
				</p>

				<h3>Where can visitors learn more about Little Boracay?</h3>
				<p>
					Visitors can explore destination information and community updates through 
					LittleBoracay.com and the official Little Boracay community channels.
				</p>

			</section>

		</main>

		<Footer />
	</body>
</html>
