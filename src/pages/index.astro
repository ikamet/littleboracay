---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main class="container">

			<!-- HERO -->
			<section class="hero">
				<h1>Little Boracay Calatagan, Batangas</h1>

				<p>
					Welcome to LittleBoracay.com — your guide to one of the most unique sandbar 
					destinations in Batangas. Discover the famous Little Boracay sandbar in 
					Calatagan, known for its crystal-clear shallow waters, floating bamboo 
					cottages, and relaxing coastal day trips just a few hours from Metro Manila.
				</p>
			</section>

			<!-- DESTINATION INTRO -->
			<section>
				<h2>Discover Little Boracay</h2>

				<p>
					Little Boracay is a scenic sandbar located off the coast of 
					<strong>Calatagan, Batangas</strong>. Known for its shallow turquoise waters 
					and wide white sand areas, the destination offers a beach experience that 
					has become popular among travelers looking for a quick escape from the city.
				</p>

				<p>
					Accessible by boat from the coastal barangays of Calatagan, the sandbar is 
					known for its floating cottages where visitors gather to relax, swim, and 
					enjoy panoramic sea views.
				</p>

				<p>
					LittleBoracay.com serves as an informational platform dedicated to helping 
					travelers understand the destination, plan their visit, and discover the 
					unique sandbar environment that makes Little Boracay one of Batangas’ most 
					talked-about coastal attractions.
				</p>
			</section>

			<!-- THINGS TO DO -->
			<section>
				<h2>Things to Do in Little Boracay</h2>

				<ul>
					<li>Boat tours to the Little Boracay sandbar</li>
					<li>Floating cottage gatherings on the water</li>
					<li>Swimming in calm shallow coastal waters</li>
					<li>Snorkeling and water activities</li>
					<li>Beach photography and drone photography</li>
					<li>Weekend beach trips from Metro Manila</li>
				</ul>

				<p>
					The sandbar environment changes with the tides, creating a constantly 
					evolving coastal landscape that attracts beach lovers, photographers, 
					and day-trip travelers.
				</p>
			</section>

			<!-- HOW TO GET THERE -->
			<section>
				<h2>How to Get to Little Boracay Calatagan</h2>

				<p>
					Travelers typically drive from Metro Manila to Calatagan, Batangas, a 
					journey that usually takes three to four hours depending on traffic.
				</p>

				<p>
					Once in Calatagan, visitors arrange a short boat transfer from the coast 
					to reach the Little Boracay sandbar where floating cottages are anchored.
				</p>

				<p>
					Boat access may vary depending on weather conditions and tides.
				</p>
			</section>

			<!-- WHY VISIT -->
			<section>
				<h2>Why Visit Little Boracay?</h2>

				<ul>
					<li>A unique sandbar experience in Batangas</li>
					<li>Floating cottages directly over shallow waters</li>
					<li>Clear coastal waters ideal for swimming</li>
					<li>Popular for family outings and group trips</li>
					<li>A scenic alternative to more distant island destinations</li>
				</ul>
			</section>

			<!-- COMMUNITY SECTION -->
			<section>
				<h2>Connect With the Little Boracay Community</h2>

				<p>
					Follow our official page at 
					<a href="https://facebook.com/littleboracay" target="_blank" rel="noopener">
						facebook.com/littleboracay
					</a>
					and become part of a growing community of travelers, beach lovers, and 
					visitors discovering the Little Boracay sandbar in Calatagan, Batangas.
				</p>

				<p>
					Join our official Facebook group for travel discussions, visitor photos, 
					tips about floating cottages, and updates about visiting the sandbar:
				</p>

				<p>
					<a href="https://facebook.com/groups/littleboracay" target="_blank" rel="noopener">
						facebook.com/groups/littleboracay
					</a>
				</p>
			</section>

			<!-- FAQ -->
			<section>
				<h2>Frequently Asked Questions</h2>

				<h3>Is Little Boracay a beach resort?</h3>
				<p>
					No. Little Boracay is a natural sandbar destination accessed by boat 
					from the coast of Calatagan.
				</p>

				<h3>Are floating cottages available?</h3>
				<p>
					Yes. Floating bamboo cottages are one of the defining features of the 
					Little Boracay experience and provide shaded spaces for visitors.
				</p>

				<h3>How far is Little Boracay from Manila?</h3>
				<p>
					Calatagan is approximately three to four hours from Metro Manila by car.
				</p>

				<h3>Is Little Boracay family-friendly?</h3>
				<p>
					Yes. The shallow waters make it suitable for families, though supervision 
					is recommended when swimming.
				</p>

				<h3>Where can I learn more about visiting?</h3>
				<p>
					Visitors can explore travel information, visitor experiences, and updates 
					through LittleBoracay.com and the official Little Boracay community channels.
				</p>

			</section>

		</main>

		<Footer />
	</body>
</html>
