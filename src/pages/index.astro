<script>
/* Smooth scroll */
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const id = a.getAttribute('href').slice(1);
    const t = document.getElementById(id);
    if (!t) return;
    e.preventDefault();
    window.scrollTo({ top: t.getBoundingClientRect().top + window.scrollY - 68, behavior: 'smooth' });
    document.getElementById('mob-nav')?.setAttribute('aria-hidden','true');
    document.getElementById('burger')?.classList.remove('open');
  });
});

/* Burger */
document.getElementById('burger')?.addEventListener('click', function() {
  const n = document.getElementById('mob-nav');
  const open = n?.getAttribute('aria-hidden') === 'true';
  n?.setAttribute('aria-hidden', open ? 'false' : 'true');
  this.setAttribute('aria-expanded', open ? 'true' : 'false');
  this.classList.toggle('open', open);
});

/* Scroll shadow */
window.addEventListener('scroll', () => {
  document.getElementById('nav')?.classList.toggle('scrolled', window.scrollY > 16);
}, { passive: true });

/* Active link */
const sec_ids = ['about','activities','visit','reviews','faq','contact'];
const navAs = document.querySelectorAll('.nav-links a, .mob-nav a');
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting)
      navAs.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + e.target.id));
  });
}, { rootMargin: '-25% 0px -65% 0px' });
sec_ids.forEach(id => { const el = document.getElementById(id); if (el) obs.observe(el); });

/* Forms */
function bindForm(fId, bId, oId) {
  const form = document.getElementById(fId);
  const btn  = document.getElementById(bId);
  const ok   = document.getElementById(oId);
  if (!form) return;
  form.addEventListener('submit', e => {
    e.preventDefault();
    if (btn) { btn.textContent = 'Sending…'; btn.disabled = true; }
    setTimeout(() => {
      form.querySelectorAll('input,select,textarea').forEach(el => el.style.display = 'none');
      form.querySelectorAll('label').forEach(el => el.style.display = 'none');
      form.querySelectorAll('.field-row,.field').forEach(el => el.style.display = 'none');
      if (btn) btn.style.display = 'none';
      if (ok)  ok.style.display = 'flex';
    }, 1100);
  });
}
bindForm('planForm','planBtn','planOk');
bindForm('contactForm','contactBtn','contactOk');
</script>

<style>
/* ════ DESIGN TOKENS ════
   Aspect-inspired: white/grey base
   Accents: navy #0D2B6B + yellow #FFD600
*/
:root {
  --navy:      #0D2B6B;
  --navy-l:    #1e3f8a;
  --yellow:    #FFD600;
  --yellow-l:  #FFF9CC;
  --bg:        #ffffff;
  --bg-alt:    #F7F7F5;
  --border:    #E5E7EB;
  --border-d:  #D1D5DB;
  --text:      #111827;
  --text-2:    #6B7280;
  --text-3:    #9CA3AF;
  --radius:    8px;
  --radius-lg: 14px;
  --radius-xl: 20px;
  --shadow-xs: 0 1px 2px rgba(0,0,0,.05);
  --shadow-sm: 0 1px 6px rgba(0,0,0,.08);
  --shadow-md: 0 4px 20px rgba(0,0,0,.08);
  --max:       1160px;
  --nav-h:     64px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }
body { font-family: -apple-system, 'Inter', 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; }
a { color: var(--navy); text-decoration: none; }
img { max-width: 100%; height: auto; display: block; }

/* ── NAV ── */
.nav { position: sticky; top: 0; z-index: 200; background: rgba(255,255,255,.97); border-bottom: 1px solid transparent; transition: border-color .2s, box-shadow .2s; backdrop-filter: blur(10px); }
.nav.scrolled { border-bottom-color: var(--border); box-shadow: var(--shadow-xs); }
.nav-inner { max-width: var(--max); margin: 0 auto; padding: 0 24px; height: var(--nav-h); display: flex; align-items: center; gap: 32px; }
.logo-link { display: flex; align-items: center; gap: 10px; text-decoration: none; flex-shrink: 0; }
.logo-img { border-radius: 50%; object-fit: cover; }
.logo-name { font-size: .95rem; font-weight: 700; color: var(--navy); letter-spacing: -.01em; }
.logo-sub { font-size: .68rem; color: var(--text-2); display: block; }
.nav-links { display: flex; align-items: center; gap: 0; margin-left: auto; }
.nav-links a { padding: 6px 13px; font-size: .865rem; font-weight: 500; color: var(--text-2); border-radius: var(--radius); transition: color .15s, background .15s; }
.nav-links a:hover, .nav-links a.active { color: var(--navy); background: rgba(13,43,107,.06); }
.nav-btn { margin-left: 12px; padding: 8px 20px; background: var(--navy); color: white; border-radius: var(--radius); font-size: .865rem; font-weight: 600; text-decoration: none; transition: background .15s; white-space: nowrap; }
.nav-btn:hover { background: var(--navy-l); color: white; }
.burger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; margin-left: auto; }
.burger span { display: block; width: 20px; height: 1.5px; background: var(--text); border-radius: 2px; transition: .22s; }
.burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.burger.open span:nth-child(2) { opacity: 0; }
.burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
.mob-nav { display: none; flex-direction: column; padding: 10px 24px 20px; border-top: 1px solid var(--border); gap: 2px; }
.mob-nav[aria-hidden="false"] { display: flex; }
.mob-nav a { padding: 9px 12px; border-radius: var(--radius); color: var(--text); font-weight: 500; font-size: .9rem; }
.mob-nav a:hover { background: var(--bg-alt); }

/* ── HERO ── */
.hero { padding: 80px 0 72px; border-bottom: 1px solid var(--border); }
.hero-inner { max-width: var(--max); margin: 0 auto; padding: 0 24px; display: grid; grid-template-columns: 1fr 420px; gap: 64px; align-items: center; }
.hero-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-size: .78rem; font-weight: 600; color: var(--text-2); letter-spacing: .04em; text-transform: uppercase; margin-bottom: 20px; }
.eyebrow-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--yellow); border: 1px solid rgba(0,0,0,.1); }
h1 { font-size: clamp(2.4rem, 4.5vw, 3.5rem); font-weight: 800; color: var(--text); line-height: 1.08; letter-spacing: -.03em; margin-bottom: 20px; }
.h1-accent { color: var(--navy); position: relative; }
.h1-accent::after { content: ''; position: absolute; bottom: 2px; left: 0; right: 0; height: 3px; background: var(--yellow); border-radius: 2px; }
.hero-sub { font-size: 1.05rem; color: var(--text-2); max-width: 480px; line-height: 1.7; margin-bottom: 28px; }
.hero-sub strong { color: var(--text); }
.hero-ctas { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 36px; }
.btn-primary { display: inline-flex; align-items: center; gap: 6px; padding: 11px 24px; background: var(--navy); color: white; border-radius: var(--radius); font-size: .9rem; font-weight: 600; text-decoration: none; transition: background .15s; border: none; cursor: pointer; }
.btn-primary:hover { background: var(--navy-l); color: white; text-decoration: none; }
.btn-outline { display: inline-flex; align-items: center; gap: 6px; padding: 11px 24px; background: transparent; color: var(--navy); border: 1.5px solid var(--border-d); border-radius: var(--radius); font-size: .9rem; font-weight: 600; text-decoration: none; transition: border-color .15s, background .15s; }
.btn-outline:hover { border-color: var(--navy); background: rgba(13,43,107,.04); text-decoration: none; }
.hero-proof { display: inline-flex; align-items: center; gap: 20px; padding: 14px 0; border-top: 1px solid var(--border); }
.proof-item { display: flex; flex-direction: column; gap: 1px; }
.proof-item strong { font-size: .9rem; font-weight: 700; color: var(--text); }
.proof-item span { font-size: .72rem; color: var(--text-3); }
.proof-div { width: 1px; height: 28px; background: var(--border); }

.hero-visual { display: flex; align-items: center; justify-content: center; }
.hero-card-frame { position: relative; }
.hero-logo-big { width: 320px; height: 320px; border-radius: 50%; object-fit: cover; border: 1px solid var(--border); box-shadow: var(--shadow-md); }
