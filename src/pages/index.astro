---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is Little Boracay in Calatagan, Batangas?", "acceptedAnswer": { "@type": "Answer", "text": "Little Boracay is a natural tidal sandbar in Calatagan, Batangas. Known for shallow turquoise waters, white sand, and floating bamboo cottages. Accessed by boat from the coast." }},
    { "@type": "Question", "name": "How far is Little Boracay from Manila?", "acceptedAnswer": { "@type": "Answer", "text": "Approximately 3 to 4 hours from Metro Manila by car via SLEX and STAR Tollway." }},
    { "@type": "Question", "name": "Are floating cottages available?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Floating bamboo cottages are available through local boat operators at the sandbar." }},
    { "@type": "Question", "name": "Is Little Boracay the same as Boracay Island?", "acceptedAnswer": { "@type": "Answer", "text": "No. Little Boracay is a natural sandbar in Calatagan, Batangas. Boracay Island is in Malay, Aklan, accessed by plane and ferry." }},
    { "@type": "Question", "name": "What is the best time to visit Little Boracay?", "acceptedAnswer": { "@type": "Answer", "text": "Morning to early afternoon during low tide. Dry season from November to May offers the most reliable weather." }},
    { "@type": "Question", "name": "Is Little Boracay family-friendly?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Shallow, calm waters suitable for all ages. Adult supervision always recommended when swimming." }}
  ]
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Visit Little Boracay Calatagan Batangas",
  "step": [
    { "@type": "HowToStep", "name": "Drive from Manila", "text": "Take SLEX south then STAR Tollway toward Batangas. Exit toward Lian then proceed to Calatagan. Approximately 3–4 hours." },
    { "@type": "HowToStep", "name": "Reach the coastal jump-off", "text": "Navigate to the coastal barangays of Calatagan where local boat operators are based." },
    { "@type": "HowToStep", "name": "Take the boat to the sandbar", "text": "Short boat transfer to Little Boracay sandbar — approximately 10–20 minutes." },
    { "@type": "HowToStep", "name": "Enjoy the sandbar", "text": "Rent a floating bamboo cottage and enjoy the shallow crystal-clear waters." }
  ]
};
---

<BaseLayout
  title="Little Boracay Calatagan Batangas | Sandbar &amp; Tours"
  description="Explore Little Boracay in Calatagan, Batangas. Boat tours, floating cottages, crystal waters, white sandbars, and water activities near Calatagan beach."
  noShell={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} slot="head" />

<!-- ═══════════════ NAV ═══════════════ -->
