}
@media (max-width: 600px) {
  .about-feats { grid-template-columns: 1fr; }
  .hero-stats { flex-wrap: wrap; gap: 10px; }
  .hstat-div { display: none; }
  .visit-seasons { grid-template-columns: 1fr; }
}
</style>
