---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustStrip from '../components/TrustStrip.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Little Boracay Sandbar",
  "description": "A natural tidal sandbar in Calatagan, Batangas with shallow turquoise waters and white sand.",
  "address": { "@type": "PostalAddress", "addressLocality": "Calatagan", "addressRegion": "Batangas", "addressCountry": "PH" },
  "geo": { "@type": "GeoCoordinates", "latitude": "13.8198041", "longitude": "120.6157737" }
};
---
<BaseLayout
  title="Little Boracay Sandbar Calatagan Batangas | Natural Tidal Sandbar"
  description="The Little Boracay sandbar in Calatagan, Batangas is a natural tidal formation with shallow turquoise waters, white sand, and floating bamboo cottages. Learn everything about this unique destination."
  schema={schema}
>
<div class="page-hero">
  <div class="container">
    <span class="overline">The Destination</span>
    <h1>The Little Boracay Sandbar</h1>
    <p class="page-lead">A natural tidal sandbar off the coast of Calatagan, Batangas — white sand, turquoise-clear shallow water, and floating bamboo cottages.</p>
  </div>
</div>
<TrustStrip />
<section class="section">
  <div class="container">
    <div class="two-col">
      <div>
        <h2 class="section-title">What is the Little Boracay Sandbar?</h2>
        <p>The <strong>Little Boracay sandbar</strong> is a natural tidal formation located off the western coastline of <strong>Calatagan, Batangas</strong>, facing the South China Sea. Unlike a developed beach resort, it is entirely a natural environment — a shifting sandbar that emerges and changes with the tides.</p>
        <p>The sandbar features wide stretches of white sand and shallow, crystal-clear water that is warm, calm, and safe for swimming. The water's remarkable turquoise colour comes from the white sandy bottom and the angle of light — similar to what makes Boracay Island in Aklan famous.</p>
        <p>The destination earned the name "Little Boracay" because of this visual similarity to Boracay Island — but at a fraction of the distance and cost from Manila.</p>
        <h3 style="margin-top:28px;margin-bottom:12px;">The Tidal Nature of the Sandbar</h3>
        <p>One of the most unique aspects of Little Boracay is that the sandbar constantly changes with the tides. During low tide — particularly in the morning hours — the sandbar is at its widest and most accessible. As the tide rises throughout the day, water levels increase and the visible sandbar narrows. This makes every visit slightly different.</p>
        <div class="info-callout">
          <strong>Best tip:</strong> Visit in the morning during low tide for the widest sandbar, best photography, and calmest water conditions.
        </div>
        <h3 style="margin-top:28px;margin-bottom:12px;">Little Boracay vs. Boracay Island — What's the Difference?</h3>
        <div class="compare-table">
          <table>
            <thead><tr><th>Feature</th><th>Little Boracay (Calatagan)</th><th>Boracay Island (Aklan)</th></tr></thead>
            <tbody>
              <tr><td>Location</td><td>Calatagan, Batangas</td><td>Malay, Aklan</td></tr>
              <tr><td>From Manila</td><td>3–4 hr drive</td><td>Flight + ferry (~3–4 hrs)</td></tr>
              <tr><td>Type</td><td>Natural tidal sandbar</td><td>Developed island resort</td></tr>
              <tr><td>Accommodation</td><td>Day trip only</td><td>Full hotel options</td></tr>
              <tr><td>Crowds</td><td>Quieter, more intimate</td><td>Major tourist destination</td></tr>
              <tr><td>Cost</td><td>Lower — day trip</td><td>Higher — multi-day</td></tr>
              <tr><td>White sand</td><td>Yes</td><td>Yes (White Beach)</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <div>
        <div class="fact-table" style="position:sticky;top:80px;">
          <div class="fact-table-header">Sandbar Quick Facts</div>
          <div class="fact-row"><span>Type</span><strong>Natural tidal sandbar</strong></div>
          <div class="fact-row"><span>Location</span><strong>Calatagan, Batangas</strong></div>
          <div class="fact-row"><span>Coordinates</span><strong>13.8198°N · 120.6158°E</strong></div>
          <div class="fact-row"><span>Body of water</span><strong>South China Sea</strong></div>
          <div class="fact-row"><span>Water type</span><strong>Shallow, calm, clear</strong></div>
          <div class="fact-row"><span>Access</span><strong>Boat only from coast</strong></div>
          <div class="fact-row"><span>Best visited</span><strong>Morning low tide</strong></div>
          <div class="fact-row"><span>Peak season</span><strong>November – May</strong></div>
          <div class="fact-row"><span>Photography</span><strong>Excellent — drone + beach</strong></div>
          <div class="fact-row"><span>Facilities</span><strong>Floating bamboo cottages</strong></div>
        </div>
        <a href="/contact" class="btn btn-navy" style="width:100%;justify-content:center;margin-top:12px;">Book a Visit →</a>
        <a href="https://maps.app.goo.gl/dDyEJhYkpxW2gxCt8" target="_blank" rel="noopener" class="btn btn-outline" style="width:100%;justify-content:center;margin-top:8px;">View on Google Maps →</a>
      </div>
    </div>
  </div>
</section>

<div class="cta-band">
  <div class="container cta-band-inner">
    <div><h2>Ready to See the Sandbar?</h2><p>Book your floating cottage and plan your visit to Little Boracay today.</p></div>
    <div class="cta-actions">
      <a href="/contact" class="btn btn-yellow btn-lg">Book Now</a>
      <a href="/visit" class="btn btn-outline-white btn-lg">Plan a Visit</a>
    </div>
  </div>
</div>
</BaseLayout>

<style>
.page-hero { padding: 60px 0 40px; background: linear-gradient(to bottom, rgba(13,43,107,.06), var(--bg)); border-bottom: 1px solid var(--border); }
.page-hero h1 { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 800; color: var(--text); margin: 10px 0 14px; letter-spacing: -.03em; }
.page-lead { font-size: 1.05rem; color: var(--text-2); max-width: 620px; line-height: 1.7; }
.two-col { display: grid; grid-template-columns: 1.4fr 1fr; gap: 56px; align-items: start; }
.info-callout { background: rgba(13,43,107,.06); border-left: 3px solid var(--navy); padding: 14px 18px; border-radius: 0 var(--r) var(--r) 0; margin: 20px 0; font-size: .9rem; color: var(--text); }
.compare-table { overflow-x: auto; margin-top: 16px; }
table { width: 100%; border-collapse: collapse; border-radius: var(--r-lg); overflow: hidden; box-shadow: var(--sh-xs); font-size: .86rem; }
thead { background: var(--navy); color: white; }
th { padding: 12px 16px; text-align: left; font-weight: 600; font-size: .82rem; }
td { padding: 10px 16px; color: var(--text-2); border-bottom: 1px solid var(--border); }
tr:last-child td { border-bottom: none; }
tr:nth-child(even) { background: var(--bg-alt); }
td:first-child { font-weight: 600; color: var(--text); }
@media (max-width: 900px) { .two-col { grid-template-columns: 1fr; gap: 32px; } }
</style>
