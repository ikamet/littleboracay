---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustStrip from '../components/TrustStrip.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Visit Little Boracay Calatagan Batangas from Manila",
  "description": "Step-by-step guide to travelling from Metro Manila to Little Boracay sandbar in Calatagan, Batangas.",
  "totalTime": "PT4H",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Drive from Metro Manila", "text": "Take the South Luzon Expressway (SLEX) south, then merge onto the STAR Tollway toward Batangas. Drive time is approximately 3 to 4 hours." },
    { "@type": "HowToStep", "position": 2, "name": "Navigate to Calatagan", "text": "Exit toward Lian, Batangas then follow roads to Calatagan. Use Google Maps or Waze and search Little Boracay Calatagan." },
    { "@type": "HowToStep", "position": 3, "name": "Reach the coastal jump-off point", "text": "Head to the coastal barangays of Calatagan where local boat operators are based. Book cottages in advance on weekends." },
    { "@type": "HowToStep", "position": 4, "name": "Take the boat to Little Boracay", "text": "The boat ride to the Little Boracay sandbar takes approximately 10 to 20 minutes depending on conditions." }
  ]
};
---
<BaseLayout
  title="How to Visit Little Boracay Calatagan Batangas | Travel Guide 2025"
  description="Complete travel guide to visiting Little Boracay in Calatagan, Batangas. How to get there from Manila, best time to visit, what to bring, and everything you need to plan your trip."
  schema={schema}
>
<div class="page-hero">
  <div class="container">
    <span class="overline">Travel Guide</span>
    <h1>How to Visit Little Boracay</h1>
    <p class="page-lead">Complete guide to planning a perfect trip to Little Boracay sandbar in Calatagan, Batangas — from Manila drive directions to what to pack.</p>
    <div class="hero-quick-facts">
      <div class="qf"><strong>3–4 hrs</strong><span>Drive from Manila</span></div>
      <div class="qf-div"></div>
      <div class="qf"><strong>~15 min</strong><span>Boat to sandbar</span></div>
      <div class="qf-div"></div>
      <div class="qf"><strong>Bring cash</strong><span>PHP · no cards</span></div>
      <div class="qf-div"></div>
      <div class="qf"><strong>Nov–May</strong><span>Best season</span></div>
    </div>
  </div>
</div>
<TrustStrip />

<section class="section" id="how-to-get-there">
  <div class="container">
    <div class="visit-grid">
      <div>
        <span class="overline">Step by Step</span>
        <h2 class="section-title">How to Get to Little Boracay from Manila</h2>
        <p>Getting to Little Boracay from Metro Manila involves a drive to Calatagan, Batangas followed by a short boat transfer.</p>
        <div class="step-list">
          <div class="step-item">
            <div class="step-num">01</div>
            <div class="step-content">
              <h3>Drive from Metro Manila via SLEX</h3>
              <p>Take the <strong>South Luzon Expressway (SLEX)</strong> from Metro Manila heading south, then merge onto the <strong>STAR Tollway</strong>. The drive is approximately <strong>3 to 4 hours</strong> under normal traffic conditions. On weekends, leaving by 4:30–6:00 AM is highly recommended to avoid heavy SLEX congestion.</p>
            </div>
          </div>
          <div class="step-item">
            <div class="step-num">02</div>
            <div class="step-content">
              <h3>Exit toward Lian and Navigate to Calatagan</h3>
              <p>Exit the STAR Tollway toward <strong>Lian, Batangas</strong> and follow the road to <strong>Calatagan</strong>. Use Google Maps or Waze — search "Little Boracay Calatagan" for the most direct routing. The Calatagan town proper is roughly 15–25 minutes from the coastal jump-off areas.</p>
            </div>
          </div>
          <div class="step-item">
            <div class="step-num">03</div>
            <div class="step-content">
              <h3>Reach the Boat Jump-Off Point</h3>
              <p>Head to the coastal barangays of Calatagan where local boat operators run transfers to the Little Boracay sandbar. <strong>Contact and book in advance</strong>, especially on weekends and Philippine holidays when floating cottages fill up fast.</p>
            </div>
          </div>
          <div class="step-item">
            <div class="step-num">04</div>
            <div class="step-content">
              <h3>Boat Transfer to the Sandbar</h3>
              <p>The boat ride takes <strong>10–20 minutes</strong> depending on conditions and jump-off point. Boat operations may be suspended during rough weather, strong winds, or unusually high tides. Always confirm with operators the day before your visit.</p>
            </div>
          </div>
        </div>
        <a href="/contact" class="btn btn-navy" style="margin-top:20px;">Book Your Visit →</a>
      </div>

      <div>
        <div id="best-time" class="sidebar-card">
          <h3>Best Time to Visit</h3>
          <div class="season-block season-good">
            <strong>✅ November – May (Best)</strong>
            <p>Dry season with reliable weather, calm seas, and clear skies. December through April is peak season — book ahead.</p>
          </div>
          <div class="season-block season-warn" style="margin-top:10px;">
            <strong>⚠️ June – October (Typhoon Season)</strong>
            <p>Higher chance of rain, rough seas, and typhoons. Boat operations may be suspended. Always check PAGASA forecasts before going.</p>
          </div>
          <div class="season-block" style="margin-top:10px;background:rgba(13,43,107,.06);border:1px solid rgba(13,43,107,.15);border-radius:var(--r);padding:14px 16px;">
            <strong>⏰ Best Time of Day</strong>
            <p style="margin-top:6px;">Morning is ideal — tides are typically lowest and the sandbar is widest. Aim to arrive at the jump-off point by 7–9 AM for the best experience.</p>
          </div>
        </div>

        <div class="sidebar-card" style="margin-top:16px;" id="what-to-bring">
          <h3>What to Bring</h3>
          <div class="bring-list">
            <div class="bring-item"><span class="bring-check">✓</span><div><strong>Cash (PHP)</strong> — most operators don't accept cards or e-wallets</div></div>
            <div class="bring-item"><span class="bring-check">✓</span><div><strong>High-SPF sunscreen</strong> — reflected water sun is much more intense</div></div>
            <div class="bring-item"><span class="bring-check">✓</span><div><strong>Swimwear + extra clothes</strong> — you will get wet</div></div>
            <div class="bring-item"><span class="bring-check">✓</span><div><strong>Waterproof sandals or aqua shoes</strong></div></div>
            <div class="bring-item"><span class="bring-check">✓</span><div><strong>Dry bag</strong> — for phone, wallet, and electronics</div></div>
            <div class="bring-item"><span class="bring-check">✓</span><div><strong>Water and packed food</strong> — food service at the sandbar is limited</div></div>
            <div class="bring-item"><span class="bring-check">✓</span><div><strong>Hat and UV rash guard</strong></div></div>
            <div class="bring-item"><span class="bring-check">✓</span><div><strong>Sunglasses</strong> (polarized for water glare)</div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="cta-band">
  <div class="container cta-band-inner">
    <div><h2>Ready to Plan Your Trip?</h2><p>Book a floating cottage or contact us with any questions about visiting Little Boracay.</p></div>
    <div class="cta-actions">
      <a href="/contact" class="btn btn-yellow btn-lg">Book Now</a>
      <a href="/faq" class="btn btn-outline-white btn-lg">Read the FAQ</a>
    </div>
  </div>
</div>
</BaseLayout>

<style>
.page-hero { padding: 60px 0 40px; background: linear-gradient(to bottom, rgba(13,43,107,.06), var(--bg)); border-bottom: 1px solid var(--border); }
.page-hero h1 { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 800; color: var(--text); margin: 10px 0 16px; letter-spacing: -.03em; }
.page-lead { font-size: 1.05rem; color: var(--text-2); max-width: 620px; line-height: 1.7; margin-bottom: 24px; }
.hero-quick-facts { display: inline-flex; align-items: center; gap: 20px; background: var(--bg-alt); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 14px 22px; flex-wrap: wrap; }
.qf { display: flex; flex-direction: column; gap: 2px; }
.qf strong { font-size: .88rem; font-weight: 700; color: var(--text); }
.qf span { font-size: .7rem; color: var(--text-3); }
.qf-div { width: 1px; height: 28px; background: var(--border); }
.visit-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 56px; align-items: start; }
.sidebar-card { background: var(--bg-alt); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 20px 22px; }
.sidebar-card h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 14px; }
.season-block { padding: 13px 15px; border-radius: var(--r); }
.season-block strong { display: block; font-size: .86rem; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.season-block p { font-size: .84rem; margin: 0; }
.season-good { background: var(--green-bg); border: 1px solid var(--green-bd); }
.season-warn { background: var(--amber-bg); border: 1px solid var(--amber-bd); }
.bring-list { display: flex; flex-direction: column; gap: 9px; }
.bring-item { display: flex; align-items: flex-start; gap: 9px; }
.bring-check { color: var(--navy); font-weight: 700; font-size: .8rem; flex-shrink: 0; margin-top: 2px; }
.bring-item div { font-size: .875rem; color: var(--text-2); }
.bring-item strong { color: var(--text); }
@media (max-width: 900px) { .visit-grid { grid-template-columns: 1fr; gap: 32px; } }
</style>
