---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  { q: "What is Little Boracay in Calatagan, Batangas?", a: "Little Boracay is a natural tidal sandbar located off the western coast of Calatagan, Batangas, Philippines. It is known for its shallow turquoise waters, white sand, and iconic floating bamboo cottages. It is not a beach resort — it is a natural coastal destination accessed by boat from the coastal barangays of Calatagan." },
  { q: "Is Little Boracay a beach resort?", a: "No. Little Boracay is a natural sandbar, not a developed beach resort. There are no hotel accommodations on the sandbar itself. Visitors spend the day at the sandbar and return to the mainland, or arrange overnight stays at nearby resorts in Calatagan." },
  { q: "How far is Little Boracay from Manila?", a: "Calatagan, Batangas is approximately 3 to 4 hours from Metro Manila by car, depending on traffic conditions. The route typically uses the South Luzon Expressway (SLEX) and the STAR Tollway heading toward Batangas." },
  { q: "How do I get to Little Boracay?", a: "Drive from Manila to Calatagan, Batangas via SLEX and STAR Tollway (3–4 hours). Navigate to the coastal barangays of Calatagan where local boat operators offer short boat transfers to the Little Boracay sandbar (10–20 minutes)." },
  { q: "How do I book a floating cottage at Little Boracay?", a: "Contact us through our website contact form, message us on Facebook at facebook.com/littleboracay, or contact local operators directly in Calatagan. We recommend booking 2–3 days in advance, especially on weekends and Philippine holidays." },
  { q: "Are floating cottages available at Little Boracay?", a: "Yes. Floating bamboo cottages are one of the defining features of Little Boracay. They are available through local boat operators and provide shaded, over-water spaces for groups to relax, eat, and enjoy the sandbar environment." },
  { q: "Is Little Boracay the same as Boracay Island in Aklan?", a: "No. Little Boracay is a completely separate destination in Calatagan, Batangas. It earned the nickname because of similar white sand and turquoise water. Boracay Island is in Malay, Aklan and requires a flight and ferry from Manila." },
  { q: "What is the best time to visit Little Boracay?", a: "Morning to early afternoon during low tide is best — the sandbar is widest and most accessible. The dry season from November to May offers the most reliable weather. Typhoon season (June to October) can bring rough seas and may affect boat operations." },
  { q: "Is Little Boracay family-friendly?", a: "Yes. The shallow, calm waters make it perfect for families including young children. Adult supervision is always recommended when swimming." },
  { q: "What should I bring to Little Boracay?", a: "Essentials: cash (PHP) — most operators don't accept cards; high-SPF sunscreen; swimwear and change of clothes; waterproof sandals; dry bag for phone and valuables; drinking water; packed food and snacks. Optional: snorkeling gear, waterproof camera, drone (check CAAP regulations)." },
  { q: "How far is Little Boracay from CaSoBe or Stilts Beach Resort?", a: "Both CaSoBe (Calatagan South Beach) and Stilts Beach Resort are located nearby along the Calatagan coastline. Many visitors combine these stops in a single day trip to the area." },
  { q: "Is Little Boracay accessible by public transport?", a: "There is no direct public transport to the Little Boracay jump-off points. Most visitors drive their own vehicle or hire a private vehicle from Manila. Some van services from Batangas City to Calatagan exist, but the boat jump-off points typically require a tricycle or additional transport once in Calatagan." },
  { q: "Can you swim at Little Boracay?", a: "Yes. Swimming is one of the main activities at Little Boracay. The clear, shallow, calm waters are ideal for swimming, wading, and relaxing. The conditions are generally safe for non-swimmers and beginners." },
  { q: "Is drone photography allowed at Little Boracay?", a: "Drone photography is popular at Little Boracay due to the stunning aerial views of the sandbar. Always follow CAAP (Civil Aviation Authority of the Philippines) regulations — register your drone, respect no-fly zones, and check with local operators about any specific restrictions." }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---
<BaseLayout
  title="Little Boracay FAQ | Frequently Asked Questions About Visiting"
  description="Answers to the most common questions about visiting Little Boracay sandbar in Calatagan, Batangas — how to get there, floating cottages, booking, best time to visit, and more."
  schema={schema}
>
<div class="page-hero">
  <div class="container">
    <span class="overline">FAQ</span>
    <h1>Frequently Asked Questions</h1>
    <p class="page-lead">Everything travelers ask before visiting Little Boracay sandbar in Calatagan, Batangas.</p>
  </div>
</div>

<section class="section">
  <div class="container faq-container">
    <div class="faq-accordion">
      {faqs.map((faq, i) => (
        <details class="faq-item" open={i === 0}>
          <summary>{faq.q}</summary>
          <div class="faq-answer"><p>{faq.a}</p></div>
        </details>
      ))}
    </div>
    <div style="margin-top:32px;text-align:center;">
      <p style="font-size:.95rem;color:var(--text-2);margin-bottom:16px;">Still have questions? We're happy to help.</p>
      <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
        <a href="/contact" class="btn btn-navy">Contact Us</a>
        <a href="https://facebook.com/groups/littleboracay" target="_blank" rel="noopener" class="btn btn-outline">Join the FB Community</a>
      </div>
    </div>
  </div>
</section>
</BaseLayout>

<style>
.page-hero { padding: 60px 0 40px; background: linear-gradient(to bottom, rgba(13,43,107,.06), var(--bg)); border-bottom: 1px solid var(--border); }
.page-hero h1 { font-size: clamp(2rem, 4vw, 2.6rem); font-weight: 800; color: var(--text); margin: 10px 0 14px; letter-spacing: -.03em; }
.page-lead { font-size: 1.05rem; color: var(--text-2); max-width: 560px; line-height: 1.7; }
.faq-container { max-width: 820px; }
</style>
