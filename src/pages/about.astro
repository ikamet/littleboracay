<style>
.page-hero { padding: 60px 0 40px; background: linear-gradient(to bottom, rgba(13,43,107,.06), var(--bg)); border-bottom: 1px solid var(--border); }
.page-hero h1 { font-size: clamp(2rem, 4vw, 2.6rem); font-weight: 800; color: var(--text); margin: 10px 0 14px; letter-spacing: -.03em; }
.page-lead { font-size: 1.05rem; color: var(--text-2); max-width: 620px; line-height: 1.7; }
.about-layout { display: grid; grid-template-columns: 1.4fr 1fr; gap: 60px; align-items: start; }
.vision-box { background: rgba(13,43,107,.05); border-left: 3px solid var(--navy); padding: 18px 22px; border-radius: 0 var(--r-lg) var(--r-lg) 0; margin: 20px 0; }
.vision-box h3 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
.vision-box p { margin: 0; font-size: .9rem; }
.community-links { display: flex; flex-direction: column; gap: 8px; }
.comm-link { display: flex; flex-direction: column; gap: 2px; padding: 12px 16px; background: var(--bg-alt); border: 1px solid var(--border); border-radius: var(--r); text-decoration: none; transition: border-color .15s; }
.comm-link:hover { border-color: var(--navy); text-decoration: none; }
.comm-link strong { font-size: .88rem; color: var(--text); }
.comm-link span { font-size: .78rem; color: var(--text-3); }
.about-sidebar { position: sticky; top: 80px; }
@media (max-width: 900px) { .about-layout { grid-template-columns: 1fr; } .about-sidebar { position: static; } }
</style>
