<style>
.page-hero {
  padding: 60px 0 40px;
  background: linear-gradient(to bottom, var(--color-ocean-light), var(--color-sand));
}
.page-hero h1 { font-size: 2.4rem; margin: 16px 0 16px; }
.page-lead { font-size: 1.05rem; color: #444; max-width: 640px; }

.about-grid {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 56px;
  align-items: start;
}
.about-grid h2 { font-size: 1.7rem; margin-bottom: 16px; }
.about-grid p { color: #444; margin-bottom: 16px; line-height: 1.7; }

.vision-box {
  background: var(--color-ocean-light);
  border-left: 4px solid var(--color-ocean);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  padding: 20px 24px;
  margin: 8px 0;
}
.vision-box h3 { font-size: 1rem; margin-bottom: 8px; color: var(--color-ocean-deep); }
.vision-box p { margin: 0; color: #444; }

.community-links { display: flex; flex-direction: column; gap: 12px; margin-top: 8px; }
.community-link {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 14px 18px;
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  text-decoration: none;
  transition: border-color 0.15s, box-shadow 0.15s;
}
.community-link:hover { border-color: var(--color-ocean); box-shadow: var(--shadow-sm); text-decoration: none; }
.community-link strong { font-size: 0.9rem; color: var(--color-ink); }
.community-link span { font-size: 0.82rem; color: var(--color-muted); }

.about-sidebar { display: flex; flex-direction: column; gap: 16px; position: sticky; top: 90px; }
.sidebar-card {
  background: var(--color-white);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
  padding: 20px;
}
.sidebar-card h3 { font-size: 0.95rem; margin-bottom: 8px; }
.sidebar-card p { font-size: 0.88rem; color: #444; margin: 0; line-height: 1.6; }

@media (max-width: 900px) {
  .about-grid { grid-template-columns: 1fr; gap: 40px; }
  .about-sidebar { position: static; }
}
</style>
